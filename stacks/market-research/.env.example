# Copy to secrets.env, fill in real values, then ENCRYPT:
#   cp .env.example secrets.env && nano secrets.env
#   sops --encrypt --in-place secrets.env
# deploy.sh decrypts secrets.env -> .env on the server. Never commit a plaintext secrets.env.

# --- Postgres (reuse existing devcore postgres/pgvector) ---
# Use the postgres container name as host since worker shares the data network.
PG_DSN=postgresql://admin:CHANGE_ME@devcore-postgres:5432/market_research

# --- Redis (reuse existing) — queue + cache ---
REDIS_URL=redis://devcore-redis:6379/3

# --- MinIO (reuse existing) — raw page storage ---
MINIO_ENDPOINT=devcore-minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# --- Crawl4AI ---
CRAWL4AI_API_TOKEN=CHANGE_ME_RANDOM_STRING

# --- Meilisearch ---
MEILI_MASTER_KEY=CHANGE_ME_RANDOM_STRING

# --- Cloud embeddings (NO GPU on this box → embeddings via API) ---
# e.g. an OpenAI/Voyage/Cohere key, or your own gateway. Used to fill chunks.embedding.
EMBEDDING_API_KEY=CHANGE_ME
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
