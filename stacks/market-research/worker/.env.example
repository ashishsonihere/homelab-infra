# Copy to secrets.env, fill, then SOPS-encrypt. Worker reads decrypted .env on the server.

# --- Reddit API app (create at https://www.reddit.com/prefs/apps , type = "script") ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=linux:market-research:v1.0 (by u/YOURNAME)

# --- Targets ---
SUBREDDITS=shopify,FulfillmentByAmazon,AmazonPPC,EtsySellers,ecommerce,smallbusiness
POSTS_PER_SUB=300

# --- YouTube connector (connectors/youtube.py + youtube_analyze.py) ---
YT_SEEDS=https://www.youtube.com/watch?v=dQw4w9WgXcQ
YT_MODE=urls                 # urls | channels | keywords
YT_MAX_VIDEOS=50
YT_FETCH_COMMENTS=0          # 1 to pull comments (slow)
YT_COMMENT_LIMIT=200
YT_LANGS=en
YT_TRANSLATE=                # set a target lang (e.g. en) to translate non-preferred transcripts
YT_PROXY=                    # optional http(s) proxy for transcript fetches (IpBlocked recovery)
# Analysis (connectors/youtube_analyze.py) — shares OPENROUTER_API_KEY below
OPENROUTER_API_KEY=
YT_MODEL=openai/gpt-4o-mini
YT_ANALYSIS_MAX=200

# --- Existing services on devcore_net (container names) ---
PG_DSN=postgresql://devcore:CHANGE_ME@devcore-postgres:5432/market_research
REDIS_URL=redis://devcore-redis:6379/4
MINIO_ENDPOINT=http://devcore-minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=market-research
