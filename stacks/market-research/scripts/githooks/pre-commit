#!/usr/bin/env bash
# pre-commit hook (source) — keeps CLAUDE.md + GEMINI.md in sync with AGENTS.md.
#
# Install with:  bash stacks/market-research/scripts/install-hooks.sh
# (it copies this file to .git/hooks/pre-commit and makes it executable).
#
# What it does on every `git commit`:
#   1. Re-copies AGENTS.md → CLAUDE.md and GEMINI.md (self-heal).
#   2. Asserts the copies now match AGENTS.md byte-for-byte.
#   3. Re-stages the copies so the commit includes the synced versions.
#   4. Exits 1 if AGENTS.md itself isn't staged (so you never sync a stale AGENTS.md)
#      OR if the sync failed — fix the cause and re-commit.
#
# This is the "pre-commit sync approach" called for in TB-D step 3 (Windows can't
# symlink reliably, so we ship plain copies + this hook keeps them in lockstep).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
# Run from the repo root so repo-relative pathspecs (STACK_REL) match regardless
# of the cwd git (or a manual test) invoked us from.
cd "$ROOT"
# This hook lives in the `homelab-infra` repo, whose root contains the stack at
# `stacks/market-research`. STACK is absolute (for cp/hash-object); STACK_REL is
# repo-relative (for `git diff` pathspecs — git matches those reliably on Windows).
STACK_REL="stacks/market-research"
STACK="$ROOT/$STACK_REL"
AGENTS="$STACK/AGENTS.md"
CLAUDE_REL="$STACK_REL/CLAUDE.md"
GEMINI_REL="$STACK_REL/GEMINI.md"
AGENTS_REL="$STACK_REL/AGENTS.md"
SYNC="$STACK/scripts/sync-memory.sh"

if [[ ! -f "$AGENTS" ]]; then
  # Not in a repo that has this stack — nothing to do (don't block other commits).
  exit 0
fi

# Require AGENTS.md (or one of the copies) to be staged, so we never re-sync from
# an unstaged source and silently commit a drifted set.
if ! git diff --cached --name-only -- "$AGENTS_REL" "$CLAUDE_REL" "$GEMINI_REL" | grep -q .; then
  # Nothing memory-related staged — still self-heal the copies on disk so they
  # never drift, but don't block the commit.
  bash "$SYNC" >/dev/null 2>&1 || true
  exit 0
fi

# AGENTS.md is the source of truth. If only a copy (CLAUDE.md/GEMINI.md) is
# staged but AGENTS.md isn't, refuse — edits must land in AGENTS.md first.
if git diff --cached --name-only -- "$CLAUDE_REL" "$GEMINI_REL" | grep -q . \
   && ! git diff --cached --name-only -- "$AGENTS_REL" | grep -q .; then
  echo "pre-commit: refusing to commit CLAUDE.md/GEMINI.md without AGENTS.md." >&2
  echo "  Edit AGENTS.md (the source of truth), then re-commit. The copies are" >&2
  echo "  regenerated by scripts/sync-memory.sh — never edit them directly." >&2
  exit 1
fi

# Self-heal: regenerate the copies from AGENTS.md.
bash "$SYNC"

# Assert byte-equality; block the commit if it somehow drifted.
HASH_AGENTS="$(git hash-object --no-filters "$AGENTS")"
HASH_CLAUDE="$(git hash-object --no-filters "$STACK/CLAUDE.md")"
HASH_GEMINI="$(git hash-object --no-filters "$STACK/GEMINI.md")"
if [[ "$HASH_AGENTS" != "$HASH_CLAUDE" || "$HASH_AGENTS" != "$HASH_GEMINI" ]]; then
  echo "pre-commit: CLAUDE.md / GEMINI.md are out of sync with AGENTS.md even after sync." >&2
  echo "  Run 'bash stacks/market-research/scripts/sync-memory.sh' and investigate." >&2
  exit 1
fi

# Re-stage the (possibly refreshed) copies so the commit carries the synced set.
git add -- "$CLAUDE_REL" "$GEMINI_REL" 2>/dev/null || true

exit 0
