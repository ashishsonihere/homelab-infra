# === SECRETS — never commit plaintext ===
# Real env files (only *.env.example is allowed in git)
*.env
!*.env.example
.env
!.env.example

# age / SOPS private keys — NEVER commit these
*.agekey
key.txt
keys.txt
age-key*.txt
*.key
*.pem

# Decrypted secret outputs
secrets.dec.*
*.dec.yaml
*.dec.yml

# === Python ===
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# === Local junk ===
.DS_Store
Thumbs.db
*.log
*.bak
*.tmp
*.swp
*.swo

# Docker / runtime data that should live on the server, not in git
data/
volumes/
*.sqlite

# Seed data files (large, server-only)
seeds/*.txt

# Private vault (separate repo, never push here)
../homelab-vault/

# Analysis CONCLUSIONS stay private (live in homelab-vault, not here)
stacks/market-research/reports/
